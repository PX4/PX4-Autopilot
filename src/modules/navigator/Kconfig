menuconfig MODULES_NAVIGATOR
	bool "navigator"
	default n
	---help---
		Enable support for navigator

menuconfig USER_NAVIGATOR
	bool "navigator running as userspace module"
	default y
	depends on BOARD_PROTECTED && MODULES_NAVIGATOR
	---help---
		Put navigator in userspace memory

menuconfig MODE_NAVIGATOR_VTOL_TAKEOFF
	bool "Include VTOL takeoff mode support"
	default n
	depends on MODULES_NAVIGATOR
	---help---
		Add VTOL takeoff mode to enable support for MAV_CMD_NAV_VTOL_TAKEOFF.
		The VTOL takes off in MC mode and transition to FW. The mode ends with
		an infinite loiter

menuconfig NAVIGATOR_ADSB
	bool "Include traffic reporting and avoidance"
	default y
	depends on MODULES_NAVIGATOR
	---help---
		Add support for acting on ADSB transponder_report or ADSB_VEHICLE MAVLink messages.
		Actions are warnings, Loiter, Land and RTL without climb.

menuconfig NAVIGATOR_GEOFENCE_AVOIDANCE
	bool "Include geofence avoidance path planning for RTL"
	default y
	depends on MODULES_NAVIGATOR
	---help---
		Add support for RTL mode to route around geofences.

config NAVIGATOR_GEOFENCE_MAX_NODES
	int "Max graph nodes for geofence RTL planner"
	default 100
	depends on NAVIGATOR_GEOFENCE_AVOIDANCE
	---help---
		Max number of geofence vertices which the RTL planner can use.
		Replanning time (on geofence / safety margin change) is cubic, RAM usage quadratic in this number.

config RTL_MISSION_CACHE_SIZE
	int "Maximum number of mission items cached for route planning"
	default 100 if BOARD_TESTING
	default 0
	range 0 1000
	depends on MODULES_NAVIGATOR
	---help---
		Maximum number of mission items reserved in RAM for full-route planning helpers.
		Set this to 0 to disable the route-mission cache on boards that have not been sized for the extra RAM.
		Each reserved cached item uses approximately 76 bytes of heap for the lifetime of Navigator,
		so the cache costs roughly 76 * CONFIG_RTL_MISSION_CACHE_SIZE bytes. The upper bound mirrors the
		largest supported mission (CONFIG_NUM_MISSION_ITMES_SUPPORTED).

config RTL_SAFE_POINT_BATCH_SIZE
	int "Maximum rally points scored per mission-route planning batch"
	default 64 if BOARD_TESTING
	default 1
	range 1 255
	depends on MODULES_NAVIGATOR
	---help---
		Number of rally (safe) points held in the fixed-size projection batch buffer that the
		route planner scores in a single scan of the mission route.

		When more eligible rally points are configured than fit in one batch, the planner
		evaluates them in successive batches, re-scanning the full mission route once per batch,
		and keeps the lowest-cost safe point across all batches (no rally point is skipped).
		A larger value trades RAM for fewer mission passes when many rally points are configured;
		boards with spare RAM can raise it so all rally points fit in a single pass.

		The projection batch is allocated in static RAM and is the larger hidden cost: it reserves
		roughly sizeof(ProjectionReference) * CONFIG_RTL_SAFE_POINT_BATCH_SIZE bytes (about 370 bytes
		per slot, i.e. ~24 KB at a batch size of 64).

		The default is 1 so that boards which leave route planning disabled (CONFIG_RTL_MISSION_CACHE_SIZE=0)
		do not pay the full batch RAM cost; boards that enable route planning should raise it.

		The configured batch size must stay <= 255 because the batch counters and
		indices are stored in uint8_t.
