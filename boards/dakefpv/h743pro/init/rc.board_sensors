#!/bin/sh
#
# board specific sensors init
#------------------------------------------------------------------------------

board_adc start

# Internal SPI bus ICM-42688P (SPI1), ROLL_180 (8)
icm42688p -s -b 1 -R 8 start

# Internal SPI bus ICM-42688P (SPI4), PITCH_180 (12)
icm42688p -s -b 4 -R 12 start

# OSD
atxxxx start -s

# Internal baro SPL06 on I2C2
spl06 start -X -b 2
