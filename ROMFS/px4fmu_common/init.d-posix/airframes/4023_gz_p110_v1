#!/bin/sh
#
# @name Custom eVTOL (4V+2F) - Gazebo SITL
#
# @type Standard VTOL
#
# Gazebo SITL airframe for the custom eVTOL using the p110_v1 model.
#
# SDF motor → airframe mapping (motorNumber is 0-indexed in SDF):
#   SIM_GZ_EC_FUNC1 (Motor1) → motorNumber 0  = rotor_0          vertical front-right
#   SIM_GZ_EC_FUNC2 (Motor2) → motorNumber 1  = rotor_1          vertical rear-left
#   SIM_GZ_EC_FUNC3 (Motor3) → motorNumber 2  = rotor_2          vertical front-left
#   SIM_GZ_EC_FUNC4 (Motor4) → motorNumber 3  = rotor_3          vertical rear-right
#   SIM_GZ_EC_FUNC5 (Motor5) → motorNumber 4  = left_forward_rotor
#   SIM_GZ_EC_FUNC6 (Motor6) → motorNumber 5  = right_forward_rotor
#
# SDF servo → airframe mapping (sub_topic servo_N is 0-indexed in SDF):
#   SIM_GZ_SV_FUNC1 (Servo1) → servo_0  = left_elevon
#   SIM_GZ_SV_FUNC2 (Servo2) → servo_1  = right_elevon
#   SIM_GZ_SV_FUNC3 (Servo3) → servo_2  = elevator
#   SIM_GZ_SV_FUNC4 (Servo4) → servo_3  = left_rudder
#   SIM_GZ_SV_FUNC5 (Servo5) → servo_4  = right_rudder
#

. ${R}etc/init.d/rc.vtol_defaults

PX4_SIMULATOR=${PX4_SIMULATOR:=gz}
PX4_GZ_WORLD=${PX4_GZ_WORLD:=default}
PX4_SIM_MODEL=${PX4_SIM_MODEL:=p110_v1}

param set-default SIM_GZ_EN 1

param set-default SENS_EN_ARSPDSIM 1

# Disable ESC/motor failure detection (SITL reports 0A for all ESCs)
param set-default FD_ACT_EN       0
param set-default FD_ACT_MOT_TOUT 500
param set-default FD_ESCS_EN      0

param set-default COM_PREARM_MODE 2
param set-default COM_RC_IN_MODE  1

# ── Vehicle type ──────────────────────────────────────────────────────────────
param set-default VT_TYPE  2    # Standard VTOL
param set-default MAV_TYPE 22   # MAV_TYPE_VTOL_FIXEDROTOR

# ── Control Allocator: motor geometry ─────────────────────────────────────────
# Positions in PX4 FRD frame (m), offset from CG.  Derived from p110_v1 SDF:
#   CG ≈ Gz (-1.5, 0, 0.1);  PX4_PX = Gz_X - (-1.5),  PX4_PY = -Gz_Y

param set-default CA_AIRFRAME    2
param set-default CA_ROTOR_COUNT 6

# Vertical hover rotors
param set-default CA_ROTOR0_PX  0.91
param set-default CA_ROTOR0_PY  0.76
param set-default CA_ROTOR0_KM  0.05   # CCW

param set-default CA_ROTOR1_PX -1.09
param set-default CA_ROTOR1_PY -0.76
param set-default CA_ROTOR1_KM  0.05   # CCW

param set-default CA_ROTOR2_PX  0.91
param set-default CA_ROTOR2_PY -0.76
param set-default CA_ROTOR2_KM -0.05   # CW

param set-default CA_ROTOR3_PX -1.09
param set-default CA_ROTOR3_PY  0.76
param set-default CA_ROTOR3_KM -0.05   # CW

# Forward thrust motors (AX=1 = thrust along body +X)
param set-default CA_ROTOR4_AX  1
param set-default CA_ROTOR4_AZ  0
param set-default CA_ROTOR4_PX  0.24
param set-default CA_ROTOR4_PY -1.68   # left nacelle
param set-default CA_ROTOR4_KM  0.0

param set-default CA_ROTOR5_AX  1
param set-default CA_ROTOR5_AZ  0
param set-default CA_ROTOR5_PX  0.24
param set-default CA_ROTOR5_PY  1.68   # right nacelle
param set-default CA_ROTOR5_KM  0.0

# ── Control Allocator: control surfaces ───────────────────────────────────────
param set-default CA_SV_CS_COUNT 5

# left elevon
param set-default CA_SV_CS0_TYPE  1
param set-default CA_SV_CS0_TRQ_R -0.5

# right elevon
param set-default CA_SV_CS1_TYPE  2
param set-default CA_SV_CS1_TRQ_R  0.5

# elevator
param set-default CA_SV_CS2_TYPE  3
param set-default CA_SV_CS2_TRQ_P  1.0

# left rudder (half yaw authority)
param set-default CA_SV_CS3_TYPE  4
param set-default CA_SV_CS3_TRQ_Y  0.5

# right rudder (half yaw authority)
param set-default CA_SV_CS4_TYPE  4
param set-default CA_SV_CS4_TRQ_Y  0.5

# ── Gazebo motor bridge (SIM_GZ_EC) ───────────────────────────────────────────
# MAX values match maxRotVelocity in p110_v1 model.sdf
# Vertical hover motors: Hobbywing XRotor X11 Plus, max 1400 RPM in sim
param set-default SIM_GZ_EC_FUNC1 101
param set-default SIM_GZ_EC_MIN1  10
param set-default SIM_GZ_EC_MAX1  1400

param set-default SIM_GZ_EC_FUNC2 102
param set-default SIM_GZ_EC_MIN2  10
param set-default SIM_GZ_EC_MAX2  1400

param set-default SIM_GZ_EC_FUNC3 103
param set-default SIM_GZ_EC_MIN3  10
param set-default SIM_GZ_EC_MAX3  1400

param set-default SIM_GZ_EC_FUNC4 104
param set-default SIM_GZ_EC_MIN4  10
param set-default SIM_GZ_EC_MAX4  1400

# Forward motors: TMotor MN8017 KV120, max 280 RPM in sim (large slow props)
param set-default SIM_GZ_EC_FUNC5 105
param set-default SIM_GZ_EC_MIN5  0
param set-default SIM_GZ_EC_MAX5  280

param set-default SIM_GZ_EC_FUNC6 106
param set-default SIM_GZ_EC_MIN6  0
param set-default SIM_GZ_EC_MAX6  280

# ── Gazebo servo bridge (SIM_GZ_SV) ──────────────────────────────────────────
# SIM_GZ_SV_FUNC{n} = 200+n maps to sub_topic servo_{n-1} in the SDF
param set-default SIM_GZ_SV_FUNC1 201   # left_elevon  → servo_0
param set-default SIM_GZ_SV_FUNC2 202   # right_elevon → servo_1
param set-default SIM_GZ_SV_FUNC3 203   # elevator     → servo_2
param set-default SIM_GZ_SV_FUNC4 204   # left_rudder  → servo_3
param set-default SIM_GZ_SV_FUNC5 205   # right_rudder → servo_4

# ── VTOL transition ───────────────────────────────────────────────────────────
param set-default VT_F_TRANS_THR   0.5
param set-default VT_FWD_THRUST_EN 4

# ── Fixed-wing controller tuning ─────────────────────────────────────────────
param set-default NPFG_PERIOD  12
param set-default FW_PR_FF     0.2
param set-default FW_PR_P      0.9
param set-default FW_PSP_OFF   2
param set-default FW_P_LIM_MIN -15
param set-default FW_RR_FF     0.1
param set-default FW_RR_P      0.3
param set-default FW_THR_TRIM  0.3
param set-default FW_THR_MAX   0.6
param set-default FW_THR_MIN   0.05
param set-default FW_T_CLMB_MAX 8
param set-default FW_T_SINK_MAX  2.7
param set-default FW_T_SINK_MIN  2.2

# ── Multicopter controller tuning ────────────────────────────────────────────
param set-default MC_AIRMODE    1
param set-default MC_ROLLRATE_P 0.3
param set-default MC_YAW_P      1.6

# ── Position control ─────────────────────────────────────────────────────────
param set-default MIS_TAKEOFF_ALT   10
param set-default MPC_XY_P         0.8
param set-default MPC_XY_VEL_P_ACC 3
param set-default MPC_XY_VEL_I_ACC 4
param set-default MPC_XY_VEL_D_ACC 0.1

# ── Navigation ───────────────────────────────────────────────────────────────
param set-default NAV_ACC_RAD 5
param set-default NAV_DLL_ACT 2
