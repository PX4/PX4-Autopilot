PX4_SIM_MODEL=${PX4_SIM_MODEL:=x500_lidar_down}

. ${R}etc/init.d-posix/airframes/4001_gz_x500

# GPS-Denied Rangefinder Height Fusion Config
param set-default EKF2_HGT_REF 2
