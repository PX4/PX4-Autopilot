#!/bin/sh
#
# @name Voliro Variable Tilt MuJoCo SITL
#
# @type Hexarotor x
# @class Copter
#
# @maintainer Holiday
#

. ${R}etc/init.d/rc.mc_defaults

PX4_SIMULATOR=${PX4_SIMULATOR:=mujoco}
PX4_SIM_MODEL=${PX4_SIM_MODEL:=voliro_variable_tilt}

param set-default SENS_EN_GPSSIM 1
param set-default SENS_EN_BAROSIM 1
param set-default SENS_EN_MAGSIM 1

param set SIH_VEHICLE_TYPE 4
param set-default MAV_TYPE 13

# MuJoCo thrust_1...thrust_6 order expressed in PX4 FRD. Rotor positions
# are normalized by the 0.315 m arm radius; KM is 0.015 / 0.315 with the
# reaction-torque signs converted from FLU to FRD.
param set-default CA_ROTOR_COUNT 6
param set-default CA_ROTOR0_PX 1
param set-default CA_ROTOR0_PY 0
param set-default CA_ROTOR0_KM -0.0476190476
param set-default CA_ROTOR1_PX 0.5
param set-default CA_ROTOR1_PY -0.866025404
param set-default CA_ROTOR1_KM 0.0476190476
param set-default CA_ROTOR2_PX -0.5
param set-default CA_ROTOR2_PY -0.866025404
param set-default CA_ROTOR2_KM -0.0476190476
param set-default CA_ROTOR3_PX -1
param set-default CA_ROTOR3_PY 0
param set-default CA_ROTOR3_KM 0.0476190476
param set-default CA_ROTOR4_PX -0.5
param set-default CA_ROTOR4_PY 0.866025404
param set-default CA_ROTOR4_KM -0.0476190476
param set-default CA_ROTOR5_PX 0.5
param set-default CA_ROTOR5_PY 0.866025404
param set-default CA_ROTOR5_KM 0.0476190476

# Simulator/HIL channel contract: six motors followed by six independent
# radial-axis tilt servos.
param set-default PWM_MAIN_FUNC1 101
param set-default PWM_MAIN_FUNC2 102
param set-default PWM_MAIN_FUNC3 103
param set-default PWM_MAIN_FUNC4 104
param set-default PWM_MAIN_FUNC5 105
param set-default PWM_MAIN_FUNC6 106
param set-default PWM_MAIN_FUNC7 201
param set-default PWM_MAIN_FUNC8 202
param set-default PWM_MAIN_FUNC9 203
param set-default PWM_MAIN_FUNC10 204
param set-default PWM_MAIN_FUNC11 205
param set-default PWM_MAIN_FUNC12 206

param set-default SENS_GPS0_DELAY 0
param set-default SENS_GPS1_DELAY 0
param set-default THR_MDL_FAC 1

# Reboot-scoped output-owner switch. Set this to 0 to leave the stock
# control_allocator running in conventional centered-tilt mode.
param set-default VOLA_EN 1
# F100 rounded 2.5 kgf peak target; replace with the final propulsion bench
# curve/continuous limit before hardware flight. The tilt mechanism has 450
# degrees total travel: one full revolution plus 45 degrees at either end.
param set-default VOLA_TMAX 24.5
param set-default VOLA_ARM 0.315
param set-default VOLA_KAPPA 0.015
param set-default VOLA_TILT_MIN -3.9269908
param set-default VOLA_TILT_MAX 3.9269908
param set-default VOLA_TILT_RATE 7.85
# Provisional critically damped tilt model for SITL. Identify this parameter
# from encoder step-response data before hardware flight.
param set-default VOLA_TILT_TAU 0.05
param set-default VOLA_FB_TMO 0.1

# The companion publishes only a six-DoF pose reference. Position, attitude,
# rate, gravity compensation, and wrench normalization run inside PX4.
param set-default VCTRL_EN 1

# Intentional vertical/inverted flight is normal for this fully actuated
# airframe. The stock attitude-failure angles would terminate it. A future
# Voliro safety monitor must replace these with tracking/rate/authority checks.
param set-default FD_FAIL_R 0
param set-default FD_FAIL_P 0
# Land detection must see lateral and positive body-z support thrust instead
# of treating only negative body-z thrust as throttle.
param set-default LNDMC_THR_VEC 1
